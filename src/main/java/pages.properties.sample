Select.com.irt.rbm.ecs.Brand.nullValueKey					=	MSG_PUB_SELECT@FIELD_ECS_BRAND{0}
Select.com.irt.rbm.ecs.EventType.format						=	$H{name}
Select.com.irt.rbm.ecs.EventType.sort						=	code
Select.com.irt.rbm.ecs.PromotionType.format					=	$H{name}
Select.com.irt.rbm.ecs.PromotionType.sort					=	code
Select.com.irt.rbm.ecs.Season.nullValueKey					=	MSG_PUB_SELECT@FIELD_ECS_SEASON
Select.com.irt.rbm.ecs.StoreAttrArea.format					=	$H{name}
Select.com.irt.rbm.ecs.StoreAttrArea.nullValueKey			=	MSG_PUB_SELECT@FIELD_ECS_STOREATTR_AREA{0}
Select.com.irt.rbm.ecs.StoreAttrComarea.format				=	$H{name}
Select.com.irt.rbm.ecs.StoreAttrFactor1.format				=	$H{name}
Select.com.irt.rbm.ecs.StoreAttrFactor2.format				=	$H{name}
Select.com.irt.rbm.ecs.StoreAttrScale.format				=	$H{name}
Select.com.irt.rbm.ecs.StoreAttrStatus.format				=	$H{name}
Select.com.irt.rbm.pds.Attr.format							=	$H{attrName}
Select.com.irt.rbm.pds.Channel.format						=	$H{name}
Select.com.irt.rbm.pds.Channel.nullValueKey					=	MSG_PUB_SELECT@FIELD_PDS_CHANNEL{0}
Select.com.irt.rbm.pds.UDG.format							=	$H{uDGName}
Select.com.irt.rbm.pds.UDG.sort								=	uDGName
Select.com.irt.rbm.pds.ReportCategoryCode.nullValueKey		=	MSG_PUB_SELECT@FIELD_PDS_REPORT_CATEGORY{0}
Select.com.irt.rbm.pds.Retail.format						=	$H{retailName}

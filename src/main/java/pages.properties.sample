#		.salesUserId.filteredBySalesOrgValue
################################################################################
tags.pds.ConditionTag.areaCode.usingAxisCodeLevel				=	true
tags.pds.ConditionTag.attrKindCode.format						=	$H{attrName}
tags.pds.ConditionTag.attrKindCode.selectedOnly					=	true
tags.pds.ConditionTag.attrValueCode.format						=	$H{attrName}
tags.pds.ConditionTag.brandCode.usingAxisCodeLevel				=	true
tags.pds.ConditionTag.categoryCodeC.usingAxisCodeLevel			=	true
tags.pds.ConditionTag.categoryCodeK.usingAxisCodeLevel			=	true
tags.pds.ConditionTag.channelCode.usingAxisCodeLevel			=	true
tags.pds.ConditionTag.gtin.format								=	[${gtin}] $H{itemName}
tags.pds.ConditionTag.itemUDGCode.format						=	$H{uDGName}
tags.pds.ConditionTag.reportCategoryCode.usingAxisCodeLevel		=	true
tags.pds.ConditionTag.retailGln.format							=	$H{retailName}
tags.pds.ConditionTag.retailGln.sort							=	displaySequence
tags.pds.ConditionTag.salesOrganizationCode.usingAxisCodeLevel	=	true
tags.pds.ConditionTag.salesUserId.filteredBySalesOrgValue		=	true
tags.pds.ConditionTag.skuCode.format							=	$H{skuName}
tags.pds.ConditionTag.skuUDGCode.format							=	$H{uDGName}
tags.pds.ConditionTag.storeGln.format							=	[${storeGln}] $H{storeName}

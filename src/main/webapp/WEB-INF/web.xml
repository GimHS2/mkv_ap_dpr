<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://java.sun.com/xml/ns/javaee" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:schemaLocation="http://java.sun.com/xml/ns/javaee http://java.sun.com/xml/ns/javaee/web-app_3_0.xsd"
	version="3.0">
	<context-param>
		<description>path</description>
		<param-name>configureFile</param-name>
		<param-value>/app/dpr/dportal/webapp-dpr/conf/rbmweb.conf</param-value>
	</context-param>
	<context-param>
		<param-name>appEnvId</param-name>
		<param-value>qa</param-value>
	</context-param>
	<context-param>
		<param-name>webappRootPath</param-name>
		<param-value>/app/dpr/dportal/webapp-dpr</param-value>
	</context-param>
	<context-param>
		<description>version for the deploy site</description>
		<param-name>deploy-version</param-name>
		<param-value>22</param-value>
	</context-param>
	<listener>
		<listener-class>com.irt.custom.ServletContextListener</listener-class>
	</listener>

	<!-- START SECTION: monitor role auth for javamelody &nbsp;

	<!-- END SECTION: monitor role auth for javamelody ( cred defined on tomcat-users.xml) -->

        <security-constraint>
                <web-resource-collection>
                        <web-resource-name>basic authentication</web-resource-name>
                        <url-pattern>/*</url-pattern>
                        <http-method>GET</http-method>
                        <http-method>POST</http-method>
                </web-resource-collection>
                <auth-constraint>
                        <role-name>dpr</role-name>
                </auth-constraint>

                <user-data-constraint>
                        <transport-guarantee>NONE</transport-guarantee>
                </user-data-constraint>
        </security-constraint>

        <login-config>
                <auth-method>BASIC</auth-method>
        </login-config>

	<!-- should not start with /. if tomcat alone, this will be /{contextPath}/${welcome-file} -->
	<welcome-file-list>
		<welcome-file>index.html</welcome-file>
		<welcome-file>index.jsp</welcome-file>
		<welcome-file>servlet/Login</welcome-file>
	</welcome-file-list>

	<filter>
		<filter-name>ExpiresFilter</filter-name>
		<filter-class>org.apache.catalina.filters.ExpiresFilter</filter-class>
		<init-param>
			<param-name>ExpiresByType image</param-name>
			<param-value>access plus 10 days</param-value>
		</init-param>
		<init-param>
			<param-name>ExpiresByType text/css</param-name>
			<param-value>access plus 10 hours</param-value>
		</init-param>
		<init-param>
			<param-name>ExpiresByType application/javascript</param-name>
			<param-value>access plus 10 minutes</param-value>
		</init-param>

		<init-param>
			<param-name>ExpiresDefault</param-name>
			<param-value>access plus 0 seconds</param-value>
		</init-param>
	</filter>

	<filter-mapping>
		<filter-name>ExpiresFilter</filter-name>
		<url-pattern>/*</url-pattern>
		<dispatcher>REQUEST</dispatcher>
	</filter-mapping>
	
	<filter>
		<filter-name>HttpHeaderSecurityFilter</filter-name>
		<filter-class>com.irt.servlet.filter.HttpHeaderSecurityFilter</filter-class>
		<async-supported>true</async-supported>

		<init-param>
			<param-name>antiClickJackingEnabled</param-name>
			<param-value>true</param-value>
		</init-param>

		<init-param>
			<param-name>referrerPolicyEnabled</param-name>
			<param-value>true</param-value>
		</init-param>
		<init-param>
			<param-name>referrerPolicyValue</param-name>
			<param-value>origin-when-cross-origin</param-value>
		</init-param>
		<init-param>
			<param-name>cspEnabled</param-name>
			<param-value>true</param-value>
		</init-param>
		<init-param>
			<param-name>cspValue</param-name>
			<param-value>default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://cdn.cookielaw.org https://s.go-mpulse.net; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; font-src 'self' data:; connect-src 'self'; object-src 'none'; frame-ancestors 'none';</param-value>
		</init-param>
		<init-param>
			<param-name>featurePolicyEnabled</param-name>
			<param-value>true</param-value>
		</init-param>
		<init-param>
			<param-name>featurePolicyValue</param-name>
			<param-value>autoplay 'none'; camera 'none'</param-value>
		</init-param>
		<init-param>
			<param-name>hstsEnabled</param-name>
			<param-value>true</param-value>
		</init-param>
		<init-param>
			<param-name>hstsMaxAgeSeconds</param-name>
			<param-value>31536000</param-value>
		</init-param>
		<init-param>
			<param-name>hstsIncludeSubDomains</param-name>
			<param-value>true</param-value>
		</init-param>
		<init-param>
			<param-name>hstsPreload</param-name>
			<param-value>true</param-value>
		</init-param>
	</filter>

	<filter-mapping>
		<filter-name>HttpHeaderSecurityFilter</filter-name>
		<url-pattern>/*</url-pattern>
		<dispatcher>REQUEST</dispatcher>
	</filter-mapping>

	<!--filter>
